rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // admin 여부 확인 헬퍼
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // streak 조작 방지: +1 이상 증가 불가 (admin 제외)
    function isValidStreakWrite(userId) {
      let prev = resource == null ? 0 : resource.data.get('streak', 0);
      let next = request.resource.data.get('streak', 0);
      return next <= prev + 1;
    }

    // 사용자 문서: 본인 + admin 모두 읽기 허용
    // 쓰기: admin은 제한 없음, 본인은 streak 조작 불가
    match /users/{userId} {
      allow read:  if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && isAdmin();
      allow write: if request.auth != null && request.auth.uid == userId
                      && isValidStreakWrite(userId);
    }

    // 사전 등록 학생: admin은 전체 읽기/쓰기, 신규 가입자는 "본인 이메일" 문서만 get 허용
    // (신규 학생이 최초 로그인 시 자신의 사전등록 정보를 읽어 groupIDs/이름을 자동 세팅하기 위함)
    match /invited_students/{email} {
      allow read, write: if request.auth != null && isAdmin();
      allow get: if request.auth != null
                 && request.auth.token.email != null
                 && email == request.auth.token.email.lower();
      allow delete: if request.auth != null
                    && request.auth.token.email != null
                    && email == request.auth.token.email.lower();
    }

    // 그룹 / 강사: 로그인 유저 읽기, admin 쓰기
    match /groups/{doc} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    match /teachers/{doc} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // 비유 라이브러리: 로그인 유저 읽기/쓰기 (좋아요 포함)
    match /metaphors/{doc} {
      allow read, write: if request.auth != null;
    }

    // 사전: 로그인 유저 읽기/쓰기
    match /dictionary/{doc} {
      allow read, write: if request.auth != null;
    }

    // 챕터 라벨 캐시
    match /chapterLabels/{doc} {
      allow read, write: if request.auth != null;
    }

    // 좌석 배치도: 로그인 유저 읽기, admin만 쓰기
    match /seating/{doc} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // 수업 기간 설정 (settings/course): 로그인 유저 읽기, admin만 쓰기
    match /settings/{doc} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // 퀘스트 히스토리 서브컬렉션: 본인만 읽기/쓰기, admin은 읽기만
    match /users/{userId}/questHistory/{date} {
      allow read:  if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 메모 등 개인 메타 데이터: 본인만 읽기/쓰기
    match /users/{userId}/meta/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // GitHub 파일 캐시: 로그인 유저 읽기/쓰기 (SHA 기반, 내용 불변)
    match /github_cache/{sha} {
      allow read, write: if request.auth != null;
    }
  }
}
