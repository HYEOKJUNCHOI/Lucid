{
  "base": "vs-dark",
  "inherit": true,
  "rules": [
    { "background": "282c34", "token": "" },

    { "foreground": "5c6370", "fontStyle": "italic", "token": "comment" },
    { "foreground": "5c6370", "fontStyle": "italic", "token": "comment.line" },
    { "foreground": "5c6370", "fontStyle": "italic", "token": "comment.line.double-slash" },
    { "foreground": "5c6370", "fontStyle": "italic", "token": "comment.block" },
    { "foreground": "5c6370", "fontStyle": "italic", "token": "comment.doc" },

    { "foreground": "98c379", "token": "string" },
    { "foreground": "98c379", "token": "string.quoted" },
    { "foreground": "98c379", "token": "string.quoted.double" },
    { "foreground": "98c379", "token": "string.quoted.single" },
    { "foreground": "98c379", "token": "string.quote" },
    { "foreground": "56b6c2", "token": "string.regexp" },
    { "foreground": "98c379", "token": "string.escape" },
    { "foreground": "98c379", "token": "constant.character.escape" },

    { "foreground": "d19a66", "token": "number" },
    { "foreground": "d19a66", "token": "number.float" },
    { "foreground": "d19a66", "token": "number.hex" },
    { "foreground": "d19a66", "token": "number.octal" },
    { "foreground": "d19a66", "token": "number.binary" },
    { "foreground": "d19a66", "token": "constant.numeric" },
    { "foreground": "d19a66", "token": "constant.character.numeric" },
    { "foreground": "d19a66", "token": "constant.language" },
    { "foreground": "d19a66", "token": "constant.language.null" },
    { "foreground": "d19a66", "token": "constant.language.boolean" },

    { "foreground": "c678dd", "token": "keyword" },
    { "foreground": "c678dd", "token": "keyword.control" },
    { "foreground": "c678dd", "token": "keyword.control.import" },
    { "foreground": "c678dd", "token": "keyword.control.flow" },
    { "foreground": "c678dd", "token": "keyword.java" },
    { "foreground": "c678dd", "token": "keyword.other" },
    { "foreground": "c678dd", "token": "keyword.other.new" },
    { "foreground": "56b6c2", "token": "keyword.operator" },
    { "foreground": "56b6c2", "token": "keyword.operator.comparison" },

    { "foreground": "c678dd", "token": "storage" },
    { "foreground": "c678dd", "token": "storage.type" },
    { "foreground": "c678dd", "token": "storage.type.class" },
    { "foreground": "c678dd", "token": "storage.modifier" },

    { "foreground": "e5c07b", "token": "type" },
    { "foreground": "e5c07b", "token": "type.identifier" },
    { "foreground": "e5c07b", "token": "type.identifier.java" },
    { "foreground": "e5c07b", "token": "entity.name.type" },
    { "foreground": "e5c07b", "token": "entity.name.type.class" },
    { "foreground": "e5c07b", "token": "entity.name.class" },
    { "foreground": "e5c07b", "token": "support.class" },
    { "foreground": "e5c07b", "token": "support.type" },

    { "foreground": "61afef", "token": "entity.name.function" },
    { "foreground": "61afef", "token": "entity.name.function.java" },
    { "foreground": "61afef", "token": "support.function" },
    { "foreground": "61afef", "token": "support.function.construct" },

    { "foreground": "98c379", "token": "entity.name.tag" },
    { "foreground": "c678dd", "fontStyle": "italic", "token": "entity.other.attribute-name" },

    { "foreground": "abb2bf", "token": "variable" },
    { "foreground": "abb2bf", "token": "variable.other" },
    { "foreground": "abb2bf", "token": "variable.parameter" },
    { "foreground": "d19a66", "fontStyle": "italic", "token": "variable.language" },
    { "foreground": "d19a66", "token": "variable.other.constant" },
    { "foreground": "abb2bf", "token": "variable.other.field" },

    { "foreground": "d19a66", "token": "support.constant" },

    { "foreground": "abb2bf", "token": "meta.brace" },
    { "foreground": "abb2bf", "token": "punctuation" },
    { "foreground": "abb2bf", "token": "delimiter" },

    { "foreground": "98c379", "token": "annotation" },
    { "foreground": "abb2bf", "token": "support.type.property-name.json" }
  ],
  "colors": {
    "editor.foreground": "#abb2bf",
    "editor.background": "#282c34",
    "editor.selectionBackground": "#3e4451",
    "editor.inactiveSelectionBackground": "#3e445180",
    "editor.lineHighlightBackground": "#2c313a",
    "editor.lineHighlightBorder": "#2c313a",
    "editorCursor.foreground": "#528bff",
    "editorWhitespace.foreground": "#3b4048",
    "editorLineNumber.foreground": "#4b5263",
    "editorLineNumber.activeForeground": "#abb2bf",
    "editorIndentGuide.background": "#3b4048",
    "editorIndentGuide.activeBackground": "#4b5263",
    "editorBracketMatch.background": "#3e445180",
    "editorBracketMatch.border": "#c678dd",
    "editorBracketHighlight.foreground1": "#d19a66",
    "editorBracketHighlight.foreground2": "#c678dd",
    "editorBracketHighlight.foreground3": "#61afef",
    "editorBracketHighlight.foreground4": "#d19a66",
    "editorBracketHighlight.foreground5": "#c678dd",
    "editorBracketHighlight.foreground6": "#61afef",
    "editorBracketHighlight.unexpectedBracket.foreground": "#f38ba8cc"
  }
}
